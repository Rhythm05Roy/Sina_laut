# ============================================================
# Sina Laut AI — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys.
# The backend team can swap providers by changing the keys below.

# ── Primary AI Provider: Google Gemini ──
# (used for image generation)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash-exp-image-generation
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ── Legacy Alias (backwards compatible) ──
# If GEMINI_API_KEY is not set, falls back to these:
# NANO_BANANA_API_KEY=your-key-here
# NANO_BANANA_MODEL=gemini-2.0-flash-exp-image-generation
# NANO_BANANA_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# ── Future Providers (optional — uncomment when ready) ──
# OPENAI_API_KEY=your-openai-key-here
# STABILITY_API_KEY=your-stability-key-here
# REPLICATE_API_KEY=your-replicate-key-here

# ── DataForSEO — Marketplace Keyword Research ──
# Required to enable live keyword retrieval from Amazon / Google Shopping.
# Sign up at https://dataforseo.com — Basic auth (login = your email).
# Without these, the keyword crawler runs in heuristic-only mode.
DATAFORSEO_LOGIN=your-dataforseo-email@example.com
DATAFORSEO_PASSWORD=your-dataforseo-api-password

# ── Image Output Settings ──
IMAGE_SIZE=1024x1024
OUTPUT_DIR=output
